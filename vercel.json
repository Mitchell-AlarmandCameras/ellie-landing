{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/monitor",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/health-check",
      "schedule": "0 12 * * 0"
    },
    {
      "path": "/api/link-check",
      "schedule": "0 1 * * 4"
    },
    {
      "path": "/api/run-curator",
      "schedule": "0 22 * * 0"
    },
    {
      "path": "/api/send-weekly",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/waitlist-drip",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/post-reddit",
      "schedule": "0 14 * * 2"
    },
    {
      "path": "/api/link-repair",
      "schedule": "0 */6 * * *"
    }
  ]
}
