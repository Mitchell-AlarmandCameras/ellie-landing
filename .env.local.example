# ════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# All of these must also be set in Vercel → Production env vars.
# ════════════════════════════════════════════════════════════════


# ── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
# Products → Add Product → "The Style Refresh" → $19.00 USD/month → copy Price ID

STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Resend (email) ─────────────────────────────────────────────────────────────
# resend.com → API Keys → create key
# resend.com → Domains → add stylebyellie.com → verify DNS in GoDaddy

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address (must be on your verified Resend domain)
RESEND_FROM_EMAIL=hello@stylebyellie.com

# YOUR inbox — receives every new waitlist signup + new paid member alert
RESEND_NOTIFY_EMAIL=your@email.com

# Optional: Resend Audience ID (resend.com → Audiences → create one → copy ID)
# When set, new paying members are auto-added as contacts for future broadcasts
RESEND_AUDIENCE_ID=


# ── Monday Automation ─────────────────────────────────────────────────────────
# Required for the Sunday AI curator and Monday member email blast.

# Anthropic API key for Claude (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A long random string YOU make up — used to secure the Approve link Ellie clicks
# Example: "ellie-style-2026-xK9qwZmP" (make your own, keep it private)
CURATOR_APPROVE_SECRET=your-secret-here

# Same value as CURATOR_APPROVE_SECRET (Vercel uses this to verify cron calls)
CRON_SECRET=your-secret-here


# ── App ───────────────────────────────────────────────────────────────────────
# Your live site URL — must match exactly (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://stylebyellie.com


# ── Owner access bypass (grants you free member access on any device) ─────────
# Make up a long random string — treat it like a password, NEVER share it.
# Example: "ellie-owner-2026-xK9qwZmP-stylerefresh"
# Usage:  https://stylebyellie.com/api/owner-access?secret=YOUR_SECRET
# Usage + welcome email preview:
#         https://stylebyellie.com/api/owner-access?secret=YOUR_SECRET&email=yes
# Use the SAME value across ALL Ellie sites so one secret works everywhere.
OWNER_BYPASS_SECRET=your-owner-secret-here

# ── Affiliate (Skimlinks — DO NOT use Sovrn, they deny paywalled sites) ──────
# Apply at skimlinks.com — approval 1-3 days — get Publisher ID from dashboard
# Format is a number like: 123456X12345
# ⚠️  SOVRN IS DEAD — denied stylebyellie.com Apr 2026. Never use on any Ellie site.
SKIMLINKS_PUBLISHER_ID=your_skimlinks_publisher_id_here

# ── Unsplash (automated hero images — fresh photos every Sunday) ──────────────
# unsplash.com/developers → New Application → copy Access Key
# Free tier: 50 requests/hour — more than enough for weekly automation
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
