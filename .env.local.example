# ════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ════════════════════════════════════════════════════════════════


# ── Resend (https://resend.com) ───────────────────────────────────────────────
#
# Step 1: Create a free account at https://resend.com
# Step 2: Go to API Keys → Create API Key → copy it below
# Step 3: Go to Domains → Add Domain → verify your sending domain (DNS records)
#         Until your domain is verified, you can only send TO your own
#         Resend account email. Use onboarding@resend.dev as RESEND_FROM_EMAIL
#         for local testing only.
# Step 4: Replace the placeholder values below with your real values

# Your Resend secret key  (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address — must be on a domain you've verified in Resend.
# For local dev/testing before domain setup, use:  onboarding@resend.dev
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Your business inbox — this is where new application alerts will land.
RESEND_NOTIFY_EMAIL=you@yourbusinessemail.com


# ── App base URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
